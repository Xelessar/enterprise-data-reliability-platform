# Warehouse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=data_platform
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=change_me

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Airflow
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=change_me

# Source connectors
SOURCE_API_BASE_URL=https://api.example.com
SOURCE_API_KEY=change_me
SOURCE_CSV_DIR=/opt/airflow/data/raw

# Google Cloud (optional -- blank disables the BigQuery sink, see
# etl/load.py::load_to_bigquery and config/settings.py::get_bigquery_config)
GCP_PROJECT_ID=
BIGQUERY_DATASET=data_reliability
# Set to any non-empty value (e.g. "1") to mount ./secrets/gcp-key.json into
# the Airflow containers -- see docker-compose.yml's airflow-env anchor.
GOOGLE_APPLICATION_CREDENTIALS=

# Alerting
ALERT_EMAIL_TO=
SLACK_WEBHOOK_URL=

# Data quality thresholds
DQ_SCORE_FAIL_THRESHOLD=70
VOLUME_ANOMALY_PCT_THRESHOLD=50
